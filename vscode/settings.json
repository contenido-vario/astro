{
  /* --- Configuración de Tailwind v4 --- */
  "tailwindCSS.experimental.configFile": null,
  "tailwindCSS.includeLanguages": {
    "html": "html",
    "css": "css"
  },
  "editor.quickSuggestions": {
    "strings": "on"
  },
  /* --- Silenciar falsos errores de CSS con Tailwind v4 --- */
  /* --- Ejemplo: @apply --- */
  "css.lint.unknownAtRules": "ignore",
  "tailwindCSS.hovers": true,
  "tailwindCSS.suggestions": true,
  /* --- Formateo automático al guardar (HTML y CSS limpios) --- */
  "editor.formatOnSave": true,
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "[css]": {
    "editor.defaultFormatter": "vscode.css-language-features"
  },
  /* --- Preferencias de edición para proyectos estáticos --- */
  "emmet.includeLanguages": {
    "tailwindcss": "html"
  },
  "editor.wordWrap": "on",
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#fbed80",
    "activityBar.background": "#fbed80",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#06b9a5",
    "activityBarBadge.foreground": "#15202b",
    "commandCenter.border": "#15202b99",
    "sash.hoverBorder": "#fbed80",
    "statusBar.background": "#f9e64f",
    "statusBar.foreground": "#15202b",
    "statusBarItem.hoverBackground": "#f7df1e",
    "statusBarItem.remoteBackground": "#f9e64f",
    "statusBarItem.remoteForeground": "#15202b",
    "titleBar.activeBackground": "#f9e64f",
    "titleBar.activeForeground": "#15202b",
    "titleBar.inactiveBackground": "#f9e64f99",
    "titleBar.inactiveForeground": "#15202b99"
  },
  "peacock.color": "#f9e64f" /* Hace que las líneas largas de clases de Tailwind den la vuelta y no se salgan de la pantalla */
}